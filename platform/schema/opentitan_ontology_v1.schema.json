{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/opentitan_ontology_v1.schema.json",
  "title": "OpenTitan Ontology v1",
  "type": "object",
  "required": [
    "project",
    "entity_type",
    "name",
    "labels"
  ],
  "properties": {
    "project": {
      "type": "string",
      "enum": [
        "opentitan",
        "ibex",
        "sv-tests",
        "RTLLM"
      ]
    },
    "entity_type": {
      "type": "string",
      "enum": [
        "ip_block",
        "module",
        "port",
        "instance",
        "label_proposal",
        "benchmark_task"
      ]
    },
    "name": {
      "type": "string"
    },
    "path": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "labels": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "ports": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "instances": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "metadata": {
      "type": "object"
    }
  },
  "additionalProperties": false
}